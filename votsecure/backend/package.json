{
  "name": "votsecure-backend",
  "version": "1.0.0",
  "description": "Backend API pentru sistemul de vot electronic securizat VotSecure",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
