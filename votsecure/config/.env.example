# ─── VotSecure — Variabile de mediu ──────────────────────────────────────────
# Copiați acest fișier ca `.env` și completați valorile.
# NU adăugați `.env` în git (este inclus în .gitignore).

# ── Bază de date PostgreSQL ───────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=votsecure
DB_USER=votsecure_user
DB_PASSWORD=schimbati_aceasta_parola
DB_SSL=false

# ── Server backend ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# ── Criptografie ─────────────────────────────────────────────────────────────
# Secretul JWT — generați cu: openssl rand -hex 64
JWT_SECRET=generati_un_secret_random_de_minim_64_caractere
JWT_EXPIRES_IN=8h

# Pepper pentru hash-ul parolelor (adăugat la SHA-256)
PASSWORD_PEPPER=generati_un_pepper_random_de_minim_32_caractere

# Pepper pentru token-ul anonim al alegătorului
VOTER_TOKEN_PEPPER=generati_un_alt_pepper_pentru_anonimizare

# ── Blockchain / Hardhat ──────────────────────────────────────────────────────
# URL-ul nodului Ethereum (local Hardhat sau Infura/Alchemy)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Cheia privată a contului deployer (Hardhat local — nu folosiți pe mainnet)
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# URL Sepolia (opțional, pentru testnet)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# ── Audit & Logging ───────────────────────────────────────────────────────────
LOG_LEVEL=info
AUDIT_LOG_FILE=./logs/audit.log
